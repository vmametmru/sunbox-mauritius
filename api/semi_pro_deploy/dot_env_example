# Semi-Pro Site Environment Configuration
# Auto-generated by sunbox-mauritius.com during deployment.
#
# DB credentials (DB_HOST, DB_USER, DB_PASS, and the Sunbox main DB_NAME)
# are NOT stored here — they are read automatically from the Sunbox root .env
# (3 levels up), since the semi-pro site lives under sunbox-root/pros/<slug>/.
#
# Only semi-pro-specific settings are stored here:

# Public URL of this semi-pro site (subdirectory under Sunbox)
APP_URL=https://sunbox-mauritius.com/pros/{{SLUG}}

# SHARED database for all semi-pro users (created manually in cPanel)
# Host/user/pass come from the Sunbox root .env
DB_NAME={{DB_NAME}}

# Company / site name shown on the login page
COMPANY_NAME={{COMPANY_NAME}}

# VAT rate (%)
VAT_RATE=15

# Debug (set to false in production)
API_DEBUG=false
