# Pro Site Environment Configuration
# Copy this file to .env and fill in your values
#
# NOTE: Database credentials are NOT stored here.
# They are securely managed on sunbox-mauritius.com and
# fetched at runtime via your SUNBOX_API_TOKEN.

APP_ENV=production
APP_URL=https://{{DOMAIN}}
API_DEBUG=false

# Sunbox main API connection (do not change these — pre-configured)
SUNBOX_API_URL=https://sunbox-mauritius.com/api
SUNBOX_API_TOKEN={{API_TOKEN}}
SUNBOX_DOMAIN={{DOMAIN}}

# Admin password for your pro site portal
# Generate: php -r "echo password_hash('your_password', PASSWORD_BCRYPT);"
ADMIN_PASSWORD_HASH=

# Email / SMTP (for sending quotes to clients)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
SMTP_FROM_EMAIL=
SMTP_FROM_NAME={{COMPANY_NAME}}

# VAT rate (default 15% for Mauritius)
VAT_RATE=15
