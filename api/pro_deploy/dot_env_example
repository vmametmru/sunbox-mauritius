# Pro Site Environment Configuration
# This file is auto-generated by sunbox-mauritius.com during provisioning.
# DB credentials and API token are pre-filled — no manual configuration needed.

APP_ENV=production
APP_URL=https://sunbox-mauritius.com/pros/{{DOMAIN}}
API_DEBUG=false

# Sunbox main API connection (pre-configured)
SUNBOX_API_URL=https://sunbox-mauritius.com/api
SUNBOX_API_TOKEN={{API_TOKEN}}
SUNBOX_DOMAIN={{DOMAIN}}

# Pro site database (auto-created by Sunbox, same server)
DB_HOST=localhost
DB_NAME={{DB_NAME}}
DB_USER={{DB_USER}}
DB_PASS={{DB_PASS}}

# Company info
COMPANY_NAME={{COMPANY_NAME}}

# VAT rate (default 15% for Mauritius)
VAT_RATE=15
