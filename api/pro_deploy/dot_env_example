# Pro Site Environment Configuration
# This file is auto-generated by sunbox-mauritius.com during provisioning.
#
# DB credentials (DB_HOST, DB_USER, DB_PASS) are NOT stored here.
# They are read automatically from the Sunbox root .env (3 levels up),
# since the pro site lives under sunbox-root/pros/<domain>/.
#
# Only pro-specific settings are stored here:

# Public URL of this pro site
APP_URL=https://{{DOMAIN}}

# ID of this pro user in the Sunbox database
SUNBOX_USER_ID={{USER_ID}}

# Pro site's own database name (created manually in cPanel)
# DB_HOST, DB_USER, DB_PASS come from Sunbox root .env
DB_NAME={{DB_NAME}}

# Bcrypt hash of the pro admin password
ADMIN_PASSWORD_HASH={{ADMIN_PASSWORD_HASH}}

# Company name and VAT rate
COMPANY_NAME={{COMPANY_NAME}}
VAT_RATE=15
